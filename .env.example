# Postgres = Netlify DB (managed Neon). On Netlify these are injected
# automatically by the Neon extension — you don't set them. Prisma reads:
#   NETLIFY_DATABASE_URL          (pooled)   — app runtime
#   NETLIFY_DATABASE_URL_UNPOOLED (unpooled) — migrations
# For local development run `npx netlify dev` (injects them), or paste them here:
# NETLIFY_DATABASE_URL="postgresql://...-pooler.../neondb?sslmode=require"
# NETLIFY_DATABASE_URL_UNPOOLED="postgresql://.../neondb?sslmode=require"

# WorkOS AuthKit — create a project at https://dashboard.workos.com and enable
# Google as the only connection. Then fill these in.
WORKOS_API_KEY="sk_..."
WORKOS_CLIENT_ID="client_..."
# 32+ character random string: `openssl rand -base64 32`
WORKOS_COOKIE_PASSWORD="change_me_to_a_random_32_char_min_secret"
# Must match the redirect URI registered in the WorkOS dashboard.
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/callback"
